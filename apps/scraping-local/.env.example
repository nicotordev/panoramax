# Base URL of the Panoramax API (no trailing slash)
PANORAMAX_API_URL=http://127.0.0.1:3001

# API key with scope events:write
# pnpm --dir apps/api api-key:create local-ingest --scope events:write
PANORAMAX_API_KEY=

# Identifiable User-Agent (recommended)
SCRAPER_USER_AGENT=PanoramaxLocalIngest/1.0 (+you@example.com)

# Pause between navigations to the same browser context (ms)
SCRAPER_REQUEST_DELAY_MS=2500

# Optional: set to 1 to show the browser window
# SCRAPER_HEADED=1

# CLI: run all sources forever with 10 min between passes:
#   pnpm start all --loop --cycle-sleep-ms=600000
# Subset + order:
#   pnpm start all --sources=gam,ticketplus,chile-cultura --loop
# "all" runs sources in parallel by default (one Playwright per source). Sequential:
#   pnpm start all --sequential
