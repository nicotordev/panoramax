DATABASE_URL="postgresql://postgres:postgres@localhost:5432/panoramax?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/panoramax?schema=public"
PORT=3001
HOST=0.0.0.0
# Comma-separated browser origins (scheme + host, no path). Use "*" only without credentials.
# Dev: if unset, allows http://localhost:3000 and http://127.0.0.1:3000.
# Production: if unset, allows panoramax.cl, panoramax-api.nicotordev.com, panoramax.nicotordev.com, api.panoramax.cl (https).
# CORS_ORIGIN=https://staging.example.com,http://localhost:3000
BRIGHTDATA_API_KEY=
REDIS_URL=redis://localhost:6379
OPENAI_INGEST_MODEL=gpt-5.4-mini
# Optional: model for --llm-fallback in geocode:missing-coordinates (defaults to gpt-4o-mini, then OPENAI_INGEST_MODEL)
# OPENAI_GEOCODE_MODEL=gpt-4o-mini
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
# Public base URL for assets stored in R2, e.g. https://example-bucket-id.r2.dev
R2_PUBLIC_BASE_URL=
# Runtime API keys are stored hashed in the database; create them via `pnpm --dir apps/api api-key:create <name>`.
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=

# Optional: identify your app when calling OSM Nominatim (geocoding). Required by their usage policy for production traffic.
# Example: NOMINATIM_USER_AGENT="Panoramax/1.0 (contact@yourdomain.com)"
# NOMINATIM_USER_AGENT=
# Optional: minimum milliseconds between Nominatim HTTP requests (default 1100). Lower only with your own instance.
# NOMINATIM_MIN_INTERVAL_MS=1100

# Clerk — verify session JWTs from the Next.js app (must match the same Clerk application)
CLERK_SECRET_KEY=
# Optional: comma-separated frontend origins (scheme + host). Dev default: localhost:3000.
# CLERK_AUTHORIZED_PARTIES=https://panoramax.cl,http://localhost:3000
# Optional: PEM from Clerk Dashboard → JWT templates / networkless verification
# CLERK_JWT_KEY=
